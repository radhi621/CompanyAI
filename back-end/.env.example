NODE_ENV=development
PORT=4000
MONGODB_URI=your_mongodb_atlas_connection_string
CORS_ORIGIN=http://localhost:3000
APP_TIMEZONE=Africa/Casablanca
DEFAULT_APPOINTMENT_DURATION_MINUTES=45
MAX_APPOINTMENT_DURATION_MINUTES=720
LLM_RETRIES_PER_PROVIDER=2
LLM_RETRY_BASE_DELAY_MS=250
AGENT_IDEMPOTENCY_TTL_MINUTES=1440

JWT_ACCESS_SECRET=replace_with_long_secure_access_secret
JWT_REFRESH_SECRET=replace_with_long_secure_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BOOTSTRAP_ADMIN_KEY=replace_with_secure_bootstrap_key

GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

GROQ_API_KEY=replace_with_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

QDRANT_URL=https://your-qdrant-instance-url
QDRANT_API_KEY=optional_qdrant_api_key
QDRANT_COLLECTION=medical_records
QDRANT_VECTOR_SIZE=768